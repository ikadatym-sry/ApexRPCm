LOG_LEVEL=info
STEAM_USERNAME=YOURSTEAMUSERNAME
STEAM_PASSWORD=YOURSTEAMPASSWORD
# steam = full rich presence via Steam API, ea = limited rich presence via EA API (etc. no map)
GAME_PLATFORM=steam
# Optional custom Discord app id (defaults to ApexRPC app id in code). (Not tested yet)
DISCORD_CLIENT_ID=
# Keep overriding Discord activity while ApexRPC is running, even when Apex is not detected. (Maybe broken???? Not sure)
ALWAYS_OVERRIDE_DISCORD_ACTIVITY=false
ALWAYS_OVERRIDE_DETAILS="ApexRPC is running"
ALWAYS_OVERRIDE_STATE="Waiting for Apex Legends"
# Preferred key. Legacy alias still supported: LAUNCH_APEX_IF_NESSESARY
LAUNCH_APEX_IF_NECESSARY=false
# Show the server name (Hardcoded. It cannot auto-detect the server name, you have to set it manually)
SHOW_SERVER=false
AUTO_DETECT_SERVER=true
PLAYING_ON_SERVER=
# EA mode poll frequency in milliseconds.
EA_PROCESS_POLL_INTERVAL_MS=15000
# EA mode activity texts (used when GAME_PLATFORM=ea).
EA_ACTIVITY_DETAILS="Playing Apex Legends"
EA_ACTIVITY_STATE="In game"
# Debug option
LOG_RICH_PRESENCE_KEYS=false