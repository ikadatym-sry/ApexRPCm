LOG_LEVEL=info
STEAM_USERNAME=YOURSTEAMUSERNAME
STEAM_PASSWORD=YOURSTEAMPASSWORD

# steam = full rich presence via Steam API, ea = process-based fallback mode.
GAME_PLATFORM=steam

# Optional custom Discord app id (defaults to ApexRPC app id in code).
DISCORD_CLIENT_ID=

# Preferred key. Legacy alias still supported: LAUNCH_APEX_IF_NESSESARY
LAUNCH_APEX_IF_NECESSARY=false

# Preferred key. Legacy alias still supported: Show_Server
SHOW_SERVER=false

# Try to auto-detect server/region from Steam rich presence payload.
AUTO_DETECT_SERVER=true

# Optional fallback label when auto-detection is unavailable.
PLAYING_ON_SERVER=

# EA mode poll frequency in milliseconds.
EA_PROCESS_POLL_INTERVAL_MS=15000

# EA mode activity texts (used when GAME_PLATFORM=ea).
EA_ACTIVITY_DETAILS="Playing Apex Legends (EA App)"
EA_ACTIVITY_STATE="In game"

# Logs all Steam rich presence key/value pairs when they change.
# Useful if you want to discover server-related keys for your account/build.
LOG_RICH_PRESENCE_KEYS=false