{
  "name": "apexrpc",
  "version": "1.1.0",
  "description": "RPC client for Apex Legends (Steam full mode + EA experimental mode)",
  "main": "main.js",
  "engines": {
    "node": ">=14.15.3"
  },
  "dependencies": {
    "discord-rpc": "4.0.1",
    "dotenv": "10.0.0",
    "find-process": "1.4.7",
    "prompts": "^2.4.2",
    "steam-user": "4.20.2",
    "winreg": "1.2.4",
    "winston": "3.7.2"
  },
  "scripts": {
    "start": "node main.js",
    "build": "nexe -i main.js -r node_modules/@doctormckay/steam-crypto --target windows-x64-14.15.3 -o ApexRPC.exe"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Holfz/ApexRPC.git"
  },
  "keywords": [],
